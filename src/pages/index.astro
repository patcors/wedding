---
import Layout from "../layouts/Layout.astro";

const dateShort = "16 · 04 · 2027";
const dateRoman = "MMXXVII";

// Astro prepends BASE_URL so this works whether the site is served from
// "/" or "/<repo>/" on GitHub Pages.
const invitationHref = `${import.meta.env.BASE_URL}invitation/`;
---

<Layout
  title="Patrick & Amelia · save the date"
  description="Patrick and Amelia are getting married. Full details to follow."
>
  <main class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden">
    <!-- Atomic sunburst, slowly rotating -->
    <svg
      aria-hidden="true"
      class="absolute inset-0 m-auto w-[120vmin] h-[120vmin] max-w-none text-mustard opacity-40 spin-slow"
      viewBox="-100 -100 200 200"
    >
      <g stroke="currentColor" stroke-width="0.6" fill="none">
        {Array.from({ length: 48 }).map((_, i) => (
          <line
            x1="0" y1="0"
            x2={Math.cos((i * Math.PI) / 24) * 96}
            y2={Math.sin((i * Math.PI) / 24) * 96}
            opacity={i % 4 === 0 ? 0.9 : 0.3}
          />
        ))}
        <circle r="42" stroke-width="0.6" />
        <circle r="64" stroke-width="0.3" stroke-dasharray="2 4" />
        <circle r="86" stroke-width="0.3" />
      </g>
    </svg>

    <article
      id="card"
      class="relative z-10 max-w-2xl text-center transition-opacity duration-700"
    >
      <p class="label">Save the date · {dateRoman}</p>

      <h1 class="mt-10 font-display leading-[0.85] tracking-[-0.02em]" style="font-variation-settings:'opsz' 144,'SOFT' 60,'WONK' 1;">
        <span class="block text-[clamp(3rem,12vw,8rem)]">Patrick</span>
        <span class="block font-serif italic text-ink-soft text-[clamp(1.5rem,5vw,3rem)] my-2">&amp;</span>
        <span class="block text-[clamp(3rem,12vw,8rem)]">
          <button
            id="amelia"
            type="button"
            aria-label="Amelia"
            class="font-display italic text-terracotta-deep tracking-[-0.02em] focus:outline-none focus-visible:outline-none cursor-default select-none"
            style="font-variation-settings:'opsz' 144,'SOFT' 100,'WONK' 1; background: transparent; border: 0; padding: 0;"
          >Amelia</button>
        </span>
      </h1>

      <!-- Hidden progress indicator — subtle mustard dot that grows with each click. -->
      <div class="mt-8 flex justify-center" aria-hidden="true">
        <span
          id="progress"
          class="block rounded-full bg-mustard transition-all duration-300"
          style="width:6px; height:6px; opacity:0.35;"
        ></span>
      </div>

      <p class="mt-10 font-serif italic text-2xl md:text-3xl text-ink-soft">
        are getting married.
      </p>

      <p class="mt-8 font-mono text-sm tracking-[0.4em] uppercase text-ink">
        {dateShort}
      </p>
      <p class="mt-3 font-serif italic text-lg text-ink-soft">
        Jasper's Berry &middot; Berry, NSW
      </p>

      <hr class="mt-14 mb-6 border-0 h-px bg-ink/25 mx-auto w-32" />

      <p class="font-serif text-lg text-ink-soft max-w-md mx-auto">
        Full details, schedule and RSVP are on their way. Watch your inbox &mdash;
        a proper invitation is coming soon.
      </p>
    </article>

    <!-- Footer ornament -->
    <svg
      aria-hidden="true"
      class="absolute bottom-6 left-1/2 -translate-x-1/2 text-terracotta-deep"
      width="36" height="36" viewBox="-18 -18 36 36"
    >
      <g stroke="currentColor" stroke-width="1.2">
        <line x1="-15" y1="0" x2="15" y2="0" />
        <line x1="0" y1="-15" x2="0" y2="15" />
        <line x1="-11" y1="-11" x2="11" y2="11" />
        <line x1="-11" y1="11" x2="11" y2="-11" />
      </g>
      <circle r="2.5" fill="currentColor" />
    </svg>
  </main>

  <script is:inline define:vars={{ invitationHref }}>
    (function () {
      const STORAGE_KEY = "pa_unlocked";
      const REQUIRED_CLICKS = 5;

      // ?lock=1 forces the waiting page even when unlocked (for previewing it).
      const params = new URLSearchParams(window.location.search);
      const forceLock = params.get("lock") === "1";

      if (!forceLock && localStorage.getItem(STORAGE_KEY) === "1") {
        window.location.replace(invitationHref);
        return;
      }
      if (forceLock) {
        localStorage.removeItem(STORAGE_KEY);
      }

      const btn = document.getElementById("amelia");
      const dot = document.getElementById("progress");
      const card = document.getElementById("card");
      let clicks = 0;

      btn?.addEventListener("click", () => {
        clicks += 1;
        const pct = Math.min(clicks / REQUIRED_CLICKS, 1);
        if (dot) {
          const size = 6 + pct * 22;
          dot.style.width = `${size}px`;
          dot.style.height = `${size}px`;
          dot.style.opacity = `${0.35 + pct * 0.65}`;
        }
        if (clicks >= REQUIRED_CLICKS) {
          localStorage.setItem(STORAGE_KEY, "1");
          if (card) card.style.opacity = "0";
          setTimeout(() => window.location.assign(invitationHref), 650);
        }
      });
    })();
  </script>
</Layout>
